# MindStore Environment Variables

# PostgreSQL connection (required)
DATABASE_URL=postgres://mindstore:yourpassword@localhost:5432/mindstore

# Google OAuth login (optional — for multi-user auth)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# AUTH_SECRET=your-random-secret-here

# AI Provider API keys (optional — can also be set via Settings page)
# At least one is needed for embeddings + chat. Gemini is free.
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# OLLAMA_URL=http://localhost:11434
