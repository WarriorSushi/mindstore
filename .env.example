# MindStore Environment Variables
# Copy this to .env.local and fill in your values

# ─── Required ───────────────────────────────────────────────
# PostgreSQL with pgvector extension
DATABASE_URL=postgres://mindstore:yourpassword@localhost:5432/mindstore

# ─── AI Providers (at least one required) ───────────────────
# API keys can also be configured via the Settings page in the app.
# Gemini has a generous free tier — recommended for getting started.

# Google Gemini (free tier available)
# GEMINI_API_KEY=AIza...

# OpenAI
# OPENAI_API_KEY=sk-...

# Ollama (free, local — install from https://ollama.ai)
# OLLAMA_URL=http://localhost:11434

# OpenRouter (200+ models via one key — https://openrouter.ai)
# OPENROUTER_API_KEY=sk-or-...

# Custom OpenAI-compatible API (Groq, Together, Fireworks, etc.)
# CUSTOM_API_KEY=...
# CUSTOM_API_URL=https://api.groq.com/openai/v1
# CUSTOM_API_MODEL=llama-3.3-70b-versatile

# ─── Authentication (optional) ──────────────────────────────
# Without these, MindStore runs in single-user mode (no login required).
# For multi-user, set up Google OAuth at https://console.cloud.google.com

# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# AUTH_SECRET=generate-a-random-32-char-string

# ─── Security (optional) ────────────────────────────────────
# If set, API keys are encrypted using this key instead of DATABASE_URL
# ENCRYPTION_KEY=generate-a-random-32-char-string

# ─── Server (optional) ──────────────────────────────────────
# PORT=3000
# NODE_ENV=production
