{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@mindstore/plugin-sdk": [
        "./packages/plugin-sdk/src/index.ts"
      ],
      "@mindstore/plugin-sdk/*": [
        "./packages/plugin-sdk/src/*"
      ],
      "@mindstore/plugin-runtime": [
        "./packages/plugin-runtime/src/index.ts"
      ],
      "@mindstore/plugin-runtime/*": [
        "./packages/plugin-runtime/src/*"
      ],
      "@mindstore/example-community-plugin": [
        "./packages/example-community-plugin/src/index.ts"
      ],
      "@mindstore/example-community-plugin/*": [
        "./packages/example-community-plugin/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.mts",
    "**/*.cts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
