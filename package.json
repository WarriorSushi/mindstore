{
  "name": "mindstore",
  "version": "0.1.0",
  "description": "Your knowledge, portable to any AI. Import from 12+ sources, search by meaning, connect to any AI via MCP.",
  "private": true,
  "license": "FSL-1.1-MIT",
  "homepage": "https://mindstore.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/WarriorSushi/mindstore.git"
  },
  "author": "MindStore Contributors",
  "keywords": [
    "knowledge-base",
    "second-brain",
    "personal-ai",
    "mcp",
    "semantic-search",
    "chatgpt-export",
    "knowledge-management",
    "rag",
    "pgvector",
    "nextjs"
  ],
  "workspaces": [
    "packages/*",
    "extensions/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:ci": "eslint mindstore.config.ts src/app/docs src/lib/docs.ts src/proxy.ts src/app/app/collections/page.tsx src/app/app/duplicates/page.tsx src/app/app/explore/page.tsx src/app/app/languages/page.tsx src/app/app/paths/page.tsx src/app/app/writing/page.tsx src/components/DidYouMean.tsx src/components/EmptyFeatureState.tsx src/components/SavedSearchPills.tsx src/components/SearchResultCard.tsx src/components/SearchStats.tsx src/app/api/v1/search/route.ts src/app/api/v1/search/fuzzy/route.ts src/app/api/v1/search/history/route.ts src/app/api/v1/search/suggestions/route.ts src/server/retrieval.ts",
    "lint:backlog": "eslint src/server src/app/api src/app/app src/components packages tests extensions",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "migrate": "npx tsx src/server/migrate.ts",
    "jobs:run-due": "npx tsx src/server/run-plugin-jobs.ts",
    "jobs:run-indexing": "npx tsx src/server/run-indexing-jobs.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "epub2": "^3.0.2",
    "gray-matter": "^4.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "marked": "^16.4.1",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reagraph": "^4.30.8",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.4.0",
    "uuid": "^13.0.0",
    "youtube-transcript": "^1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
