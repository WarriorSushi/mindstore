{
  "name": "mindstore-web",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "extensions/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:ci": "eslint mindstore.config.ts src/app/docs src/lib/docs.ts src/server/capture.ts src/server/extension.ts src/server/mcp src/server/plugin-jobs.ts src/server/plugins src/server/run-plugin-jobs.ts src/app/api/mcp/route.ts src/app/api/v1/capture src/app/api/v1/extension src/app/api/v1/import/route.ts src/app/api/v1/plugin-jobs src/app/api/v1/plugins/flashcard-maker/route.ts src/app/api/v1/plugins/route.ts src/app/api/v1/settings/route.ts src/app/app/connect/page.tsx src/app/app/flashcards/page.tsx src/app/app/plugins/page.tsx src/app/app/settings/page.tsx src/components/CommandPalette.tsx src/components/KeyboardShortcuts.tsx src/components/Onboarding.tsx packages tests extensions",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "migrate": "npx tsx src/server/migrate.ts",
    "jobs:run-due": "npx tsx src/server/run-plugin-jobs.ts"
  },
  "dependencies": {
