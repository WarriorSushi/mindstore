    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "marked": "^16.4.1",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reagraph": "^4.30.8",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
